# Auto detect text files and normalize line endings
* text=auto

# Go source files
*.go text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker files
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Documentation
*.md text eol=lf

# Binary files
*.exe binary
*.zip binary
*.tar binary
*.gz binary
